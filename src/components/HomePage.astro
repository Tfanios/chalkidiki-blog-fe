---
import BaseLayout from "../layouts/BaseLayout.astro";
import { type Locale, defaultLocale, localizePath } from "../lib/i18n";
import { getHomeContent } from "../lib/travel-home";

type Props = {
  locale?: Locale;
};

const { locale = defaultLocale } = Astro.props;
const {
  contactItems,
  destinationsCta,
  featuredTable,
  heroCopy,
  heroImage,
  instagramImages,
  peninsulas,
  testimonials,
  whyBlock,
} = getHomeContent(locale);

const pageDescription =
  locale === "el"
    ? "Ένα editorial ταξιδιωτικό ημερολόγιο για το φαγητό, τη φιλοξενία, τις παραλίες και τις τρεις χερσονήσους της Χαλκιδικής."
    : "An editorial travel journal for Chalkidiki's food, hospitality, beaches, and three peninsulas.";
---

<BaseLayout
  title="iLove Chalkidiki"
  description={pageDescription}
  locale={locale}
>
  <section
    class="relative isolate min-h-[100svh] overflow-hidden bg-aegean-deep text-whitewash"
    data-gsap-hero
  >
    <img
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      src={heroImage.src}
      alt={heroImage.alt}
      loading="eager"
      data-gsap="hero-image"
    />
    <div class="absolute inset-0 -z-10 bg-aegean-deep/55"></div>

    <div
      class="relative mx-auto flex min-h-[100svh] items-center justify-center px-6 py-12 sm:px-10 lg:px-16"
    >
      <div class="relative">
        <p
          class="absolute -top-16 left-1/2 -translate-x-1/2 text-xs font-semibold uppercase tracking-[0.24em] whitespace-nowrap sm:-top-24 sm:left-0 sm:translate-x-0"
          data-gsap="hero-kicker"
        >
          {heroCopy.heroEyebrow}
        </p>

        <h1
          class="text-center font-serif font-medium uppercase leading-[0.95] text-7xl sm:text-8xl lg:text-[10rem]"
          data-gsap="hero-title"
        >
          {heroCopy.heroTitleTop}<br />{heroCopy.heroTitleBottom}
        </h1>

        <p
          class="absolute -bottom-16 left-1/2 -translate-x-1/2 text-xs font-semibold uppercase tracking-[0.24em] whitespace-nowrap sm:-bottom-24 sm:left-auto sm:right-0 sm:translate-x-0"
          data-gsap="hero-subtitle"
        >
          {heroCopy.heroSubtitle}
        </p>
      </div>
    </div>
  </section>

  <section
    id="peninsulas"
    class="bg-whitewash px-4 py-24 sm:px-6 lg:px-8 lg:py-32"
    data-gsap-section
  >
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <h2
          class="font-serif text-4xl font-medium uppercase leading-tight text-aegean-deep sm:text-5xl lg:text-6xl"
          data-gsap-heading
        >
          {heroCopy.peninsulasTitle}
        </h2>
        <p
          class="mx-auto mt-6 max-w-xl text-base leading-7 text-ink-soft"
          data-gsap-copy
        >
          {heroCopy.peninsulasIntro}
        </p>
      </div>

      <div
        class="mt-16 grid gap-6 sm:grid-cols-2 lg:flex lg:min-h-136 lg:grid-cols-none lg:items-stretch"
      >
        {
          peninsulas.map((peninsula) => (
            <a
              href={localizePath(`/peninsulas/${peninsula.slug}`, locale)}
              class="relative block aspect-3/4 overflow-hidden rounded-2xl lg:h-136 lg:flex-1 lg:basis-0 lg:aspect-auto"
              data-gsap-card
              data-peninsula-card
            >
              <img
                class="absolute inset-0 h-full w-full object-cover"
                src={peninsula.image.src}
                alt={peninsula.image.alt}
                loading="lazy"
                data-peninsula-image
              />
              <div class="absolute inset-0 bg-linear-to-t from-aegean-deep/85 via-aegean-deep/25 to-transparent" />

              <div class="absolute inset-0 flex flex-col justify-end p-7 text-whitewash sm:p-8">
                <h3
                  class="font-serif text-3xl font-medium uppercase leading-none sm:text-4xl"
                  data-peninsula-title
                >
                  {peninsula.name}
                </h3>
                <div data-peninsula-details>
                  <p class="mt-4 max-w-xs text-sm leading-6 text-whitewash/90">
                    {peninsula.description}
                  </p>
                  <span class="mt-5 inline-flex items-center rounded-full bg-clay px-5 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-whitewash">
                    {heroCopy.cardCta} &rarr;
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section
    id="food"
    class="bg-sand px-4 py-20 sm:px-6 lg:px-8 lg:py-28"
    data-gsap-section
  >
    <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-2 lg:items-center">
      <img
        class="aspect-4/3 w-full rounded-md object-cover"
        src={featuredTable.image.src}
        alt={featuredTable.image.alt}
        loading="lazy"
        data-gsap-media
      />
      <div data-gsap-card>
        <p class="text-xs uppercase tracking-[0.14em] text-clay-deep">
          {featuredTable.eyebrow}
        </p>
        <h2
          class="mt-3 font-serif text-3xl font-medium leading-tight text-aegean-deep sm:text-4xl"
          data-gsap-heading
        >
          {featuredTable.title}
        </h2>
        <p
          class="mt-5 max-w-lg text-base leading-7 text-ink-soft"
          data-gsap-copy
        >
          {featuredTable.description}
        </p>
        <a
          class="mt-6 inline-flex text-sm font-semibold text-aegean hover:text-clay-deep"
          href={localizePath("/blog", locale)}
        >
          {heroCopy.featuredCta} &rarr;
        </a>
      </div>
    </div>
  </section>

  <section
    class="relative isolate overflow-hidden bg-aegean-deep py-24 text-whitewash sm:py-32 lg:py-40"
    data-gsap-section
  >
    <img
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      src={destinationsCta.image.src}
      alt={destinationsCta.image.alt}
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-aegean-deep/30"></div>

    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h2
          class="font-serif text-4xl font-medium uppercase leading-[0.95] sm:text-5xl lg:text-6xl"
          data-gsap-heading
        >
          {destinationsCta.eyebrow}
        </h2>
        <p
          class="mt-6 max-w-lg text-base leading-7 text-whitewash/85"
          data-gsap-copy
        >
          {destinationsCta.description}
        </p>
        <a
          class="mt-8 inline-flex rounded-lg bg-whitewash px-7 py-3 text-sm font-semibold text-aegean-deep transition hover:bg-sand"
          href={localizePath("/#peninsulas", locale)}
        >
          {destinationsCta.buttonLabel}
        </a>
      </div>
    </div>
  </section>

  <section
    id="why"
    class="bg-whitewash px-4 py-20 sm:px-6 lg:px-8 lg:py-28"
    data-gsap-section
  >
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
        <h2
          class="font-serif text-4xl font-medium uppercase leading-[0.95] text-aegean-deep sm:text-5xl lg:text-6xl"
          data-gsap-heading
        >
          {whyBlock.title}
        </h2>
        <div data-gsap-card>
          <p class="text-base leading-7 text-ink-soft" data-gsap-copy>
            {whyBlock.description}
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              class="rounded-lg bg-aegean-deep px-6 py-3 text-sm font-semibold text-whitewash transition hover:bg-aegean"
              href={localizePath("/#peninsulas", locale)}
            >
              {whyBlock.primary.label}
            </a>
            <a
              class="rounded-lg border border-aegean-deep/30 px-6 py-3 text-sm font-semibold text-aegean-deep transition hover:border-clay hover:text-clay-deep"
              href={localizePath("/blog", locale)}
            >
              {whyBlock.secondary.label}
            </a>
          </div>
        </div>
      </div>

      <div
        class="relative mt-14 overflow-hidden rounded-2xl lg:mt-20"
        data-gsap-media
      >
        <img
          class="aspect-video w-full object-cover"
          src={whyBlock.image.src}
          alt={whyBlock.image.alt}
          loading="lazy"
        />
        <div class="absolute inset-0 bg-aegean-deep/15"></div>
        <button
          type="button"
          aria-label="Play video"
          class="group absolute inset-0 flex items-center justify-center focus:outline-none"
        >
          <span
            class="grid h-16 w-16 place-items-center rounded-full bg-whitewash/95 text-aegean-deep shadow-lg backdrop-blur transition group-hover:scale-110 group-focus-visible:ring-2 group-focus-visible:ring-clay sm:h-20 sm:w-20"
          >
            <svg
              viewBox="0 0 24 24"
              class="ml-1 h-6 w-6 fill-current sm:h-7 sm:w-7"
              aria-hidden="true"
            >
              <path d="M8 5v14l11-7-11-7z"></path>
            </svg>
          </span>
        </button>
      </div>
    </div>
  </section>

  <section
    class="relative isolate overflow-hidden bg-aegean-deep py-16 text-whitewash sm:py-20 lg:py-24"
    data-gsap-section
  >
    <img
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      src="https://images.unsplash.com/photo-1473496169904-658ba7c44d8a?auto=format&fit=crop&w=2400&q=85"
      alt=""
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-aegean-deep/30"></div>

    <div class="overflow-hidden">
      <div class="marquee-left flex w-max items-center gap-12 pr-12">
        {
          Array.from({ length: 8 }).map(() => (
            <span class="font-serif text-5xl font-medium leading-none whitespace-nowrap sm:text-6xl lg:text-8xl">
              A coast worth slowing down for
            </span>
          ))
        }
      </div>
    </div>

    <div class="mt-3 overflow-hidden sm:mt-4">
      <div class="marquee-right flex w-max items-center gap-12 pr-12">
        {
          Array.from({ length: 8 }).map(() => (
            <span class="font-serif text-5xl font-medium italic leading-none whitespace-nowrap text-whitewash/85 sm:text-6xl lg:text-8xl">
              A coast worth slowing down for
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="bg-whitewash px-4 pb-20 sm:px-6 lg:px-8 lg:pb-28"
    data-gsap-section
  >
    <div class="mx-auto max-w-5xl border-t border-sand-deep/50 pt-16">
      <h2
        class="max-w-xl font-serif text-3xl font-medium leading-tight text-aegean-deep sm:text-4xl"
        data-gsap-heading
      >
        {heroCopy.readersTitle}
      </h2>
      <div class="mt-10 grid gap-10 md:grid-cols-3">
        {
          testimonials.map((item) => (
            <figure data-gsap-card>
              <blockquote class="font-serif text-lg italic leading-snug text-ink">
                &ldquo;{item.quote}&rdquo;
              </blockquote>
              <figcaption class="mt-5 flex items-center gap-3">
                <img
                  class="h-10 w-10 rounded-full object-cover"
                  src={item.avatar}
                  alt=""
                  loading="lazy"
                />
                <div>
                  <p class="text-sm font-semibold text-ink">{item.name}</p>
                  <p class="text-xs text-ink-soft">{item.role}</p>
                </div>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <section
    id="contact"
    class="bg-whitewash px-4 pb-20 sm:px-6 lg:px-8 lg:pb-28"
    data-gsap-section
  >
    <div class="mx-auto max-w-5xl border-t border-sand-deep/50 pt-16">
      <h2
        class="max-w-xl font-serif text-3xl font-medium leading-tight text-aegean-deep sm:text-4xl"
        data-gsap-heading
      >
        {heroCopy.contactTitle}
      </h2>
      <div class="mt-10 grid gap-8 sm:grid-cols-3">
        {
          contactItems.map((item) => (
            <div data-gsap-card>
              <p class="text-xs uppercase tracking-[0.14em] text-clay-deep">
                {item.label}
              </p>
              <a
                class="mt-2 block text-base text-ink hover:text-aegean"
                href={item.href}
              >
                {item.value}
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="bg-whitewash px-4 pb-20 sm:px-6 lg:px-8 lg:pb-28"
    data-gsap-section
  >
    <div class="mx-auto max-w-5xl border-t border-sand-deep/50 pt-16">
      <div class="flex items-end justify-between gap-5">
        <h2
          class="font-serif text-3xl font-medium leading-tight text-aegean-deep sm:text-4xl"
          data-gsap-heading
        >
          {heroCopy.instagramTitle}
        </h2>
        <a
          class="text-sm font-semibold text-aegean hover:text-clay-deep"
          href="#">{heroCopy.instagramCta} &rarr;</a
        >
      </div>
      <div class="mt-10 grid gap-3 sm:grid-cols-3">
        {
          instagramImages.map((image) => (
            <a
              href="#"
              class="group block aspect-square overflow-hidden rounded-md"
              data-gsap-card
            >
              <img
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                src={image.src}
                alt={image.alt}
                loading="lazy"
              />
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section
    id="newsletter"
    class="relative isolate overflow-hidden bg-aegean-deep py-24 text-whitewash sm:py-28 lg:py-32"
    data-gsap-section
  >
    <img
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      src="https://images.unsplash.com/photo-1516483638261-f4dbaf036963?auto=format&fit=crop&w=2000&q=85"
      alt=""
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-aegean-deep/65"></div>

    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2
        class="font-serif text-4xl font-medium uppercase leading-tight sm:text-5xl lg:text-6xl"
        data-gsap-heading
      >
        {heroCopy.newsletterTitle}
      </h2>
      <p
        class="mx-auto mt-6 max-w-xl text-base leading-7 text-whitewash/85"
        data-gsap-copy
      >
        {heroCopy.newsletterDescription}
      </p>
      <form
        class="mx-auto mt-10 grid max-w-md gap-3 sm:grid-cols-[1fr_auto]"
        action="#"
        method="post"
        data-gsap-form
      >
        <label class="sr-only" for={`email-${locale}`}>Email address</label>
        <input
          class="h-12 rounded-full bg-white px-5 text-sm text-ink outline-none placeholder:text-ink-soft/70 focus:ring-2 focus:ring-shallow/50"
          id={`email-${locale}`}
          name="email"
          type="email"
          placeholder={heroCopy.emailPlaceholder}
        />
        <button
          class="h-12 rounded-full bg-clay px-6 text-sm font-semibold text-whitewash transition hover:bg-clay-deep focus:outline-none focus:ring-2 focus:ring-clay focus:ring-offset-2 focus:ring-offset-aegean-deep"
          type="submit"
        >
          {heroCopy.subscribe}
        </button>
      </form>
    </div>
  </section>

  <script>
    import "../scripts/home-animations";
  </script>
</BaseLayout>
