<section id="subscribe" class="bg-forest text-white">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-14 sm:px-6 md:grid-cols-[1fr_0.9fr] md:items-center lg:px-8">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-moss">Newsletter</p>
      <h2 class="mt-3 max-w-2xl text-3xl font-semibold leading-tight sm:text-4xl">
        Sharp notes on building content-heavy websites.
      </h2>
    </div>
    <form class="grid gap-3 sm:grid-cols-[1fr_auto]" action="#" method="post">
      <label class="sr-only" for="email">Email address</label>
      <input
        class="h-12 rounded-sm border border-white/20 bg-white px-4 text-sm text-ink outline-none transition placeholder:text-ink/45 focus:border-brass focus:ring-2 focus:ring-brass/50"
        id="email"
        name="email"
        type="email"
        placeholder="you@example.com"
      />
      <button
        class="h-12 rounded-sm bg-brass px-5 text-sm font-semibold text-ink transition hover:bg-moss focus:outline-none focus:ring-2 focus:ring-brass focus:ring-offset-2 focus:ring-offset-forest"
        type="submit"
      >
        Subscribe
      </button>
    </form>
  </div>
</section>
